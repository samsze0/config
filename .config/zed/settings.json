// https://zed.dev/docs/configuring-zed
{
  "agent_servers": {
    "codex-acp": {
      "type": "registry",
    },
    "opencode": {
      "type": "registry",
    },
  },
  "project_panel": {
    "dock": "left",
  },
  "agent": {
    "dock": "left",
    "favorite_models": [],
    "model_parameters": [],
  },
  "base_keymap": "VSCode",
  "middle_click_paste": false,
  "inlay_hints": {
    "enabled": false,
    "toggle_on_modifiers_press": {
      "alt": true,
    },
  },
  "completion_menu_scrollbar": "always",

  "show_signature_help_after_edits": true,
  "which_key": {
    "delay_ms": 300,
    "enabled": true,
  },
  "diagnostics": {
    "inline": {
      "enabled": true,
    },
  },
  "tabs": {
    "file_icons": true,
  },
  "outline_panel": {
    "dock": "left",
  },
  "autosave": {
    "after_delay": {
      "milliseconds": 1000,
    },
  },
  "lsp_document_colors": "background",
  "git_panel": {
    "dock": "left",
    "tree_view": true,
  },
  "icon_theme": "Material Icon Theme",
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "ui_font_size": 14,
  "ui_font_family": ".SystemUIFont",
  "ui_font_weight": 400,
  "buffer_font_size": 13,
  "buffer_font_family": "Liga SFMono Nerd Font",
  "terminal": {
    "font_family": "Liga SFMono Nerd Font",
    "cursor_shape": "bar",
  },
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "GitHub Dark Tritanopia",
  },
  "vim_mode": false,
  "active_pane_modifiers": {
    "inactive_opacity": 1,
    "border_size": 1,
  },
  "experimental.theme_overrides": {
    "panel.focused_border": "#cccccc",
    "tab.active_background": "#293547",
    "tab.inactive_background": "#000000",
  },
  "hover_popover_delay": 200,
  "multi_cursor_modifier": "alt",
  "show_completions_on_input": true,
  "show_completion_documentation": true,
  "auto_signature_help": true,
  "show_edit_predictions": true,
  "soft_wrap": "editor_width",
  "format_on_save": "off",
  "extend_comment_on_newline": false,
  "edit_predictions": {
    "provider": "zed",
    "mode": "eager", // or "subtle"
  },
}
